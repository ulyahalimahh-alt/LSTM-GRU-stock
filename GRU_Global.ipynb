      "source": [
        "# BEST MODEL DETAIL METRICS\n",
        "best_result = best['result']\n",
        "best_detail = best['detail']\n",
        "best_history = best['history']\n",
        "\n",
        "best_detail.to_excel(OUTPUT_DIR / 'gru_evaluasi_detail_fixed.xlsx', index=False)\n",
        "best_history.to_excel(OUTPUT_DIR / 'gru_training_history_best.xlsx', index=False)\n",
        "\n",
        "summary = metrics_by_ticker(best_detail, best_detail['Predicted'].values)\n",
        "summary['Pass_R2_90'] = summary['R2'] > TARGET_R2\n",
        "summary['Pass_MAPE_10'] = summary['MAPE_%'] < TARGET_MAPE\n",
        "summary['Aux_Pass_DA_55'] = summary['Directional_Accuracy_%'] > AUX_TARGET_DA\n",
        "summary['Model_GT_Naive_R2'] = summary['R2'] > summary['R2_Naive']\n",
        "summary['Model_GT_Naive_MAE'] = summary['MAE'] < summary['MAE_Naive']\n",
        "summary['Model_GT_Naive_RMSE'] = summary['RMSE'] < summary['RMSE_Naive']\n",
        "summary['Primary_Price_Metrics_Pass'] = summary['Pass_R2_90'] & summary['Pass_MAPE_10']\n",
        "summary['Naive_Comparison_Note'] = np.where(\n",
        "    summary['Model_GT_Naive_MAE'] & summary['Model_GT_Naive_RMSE'],\n",
        "    'Model lebih baik dari naive pada MAE/RMSE',\n",
        "    'Model akurat, tetapi belum konsisten mengalahkan naive'\n",
        ")\n",
        "summary.to_excel(OUTPUT_DIR / 'gru_evaluasi_summary_fixed.xlsx', index=False)\n",
        "\n",
        "print('BEST CONFIG')\n",
        "print(json.dumps({k: (float(v) if isinstance(v, (np.floating, float)) else v) for k, v in best_result.items() if k in ['seq_len','hidden','layers','epochs','alpha','valid_RMSE','test_RMSE','test_R2','test_R2_Naive','test_Beat_Naive_Rate_%']}, indent=2))\n",
        "\n",
        "print('SUMMARY PER TICKER')\n",
        "display(summary.round(4))\n",
        "\n",
        "print('Target checks:')\n",
        "print('R2 > 0.90:', bool((summary['R2'] > TARGET_R2).all()))\n",
        "print('MAPE < 10% per ticker:', bool((summary[summary['Ticker'] != 'ALL']['MAPE_%'] < TARGET_MAPE).all()))\n",
        "print('DA > 55% per ticker:', bool((summary[summary['Ticker'] != 'ALL']['Directional_Accuracy_%'] > AUX_TARGET_DA).all()))\n",
        "print('Model R2 > Naive R2:', bool((summary['R2'] > summary['R2_Naive']).all()))\n",
        "print('Model MAE < Naive MAE:', bool((summary['MAE'] < summary['MAE_Naive']).all()))"
      ],
