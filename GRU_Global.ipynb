        "    print(\n",
        "        f\"  valid R2={result['valid_R2']:.4f} | valid RMSE={result['valid_RMSE']:.4f} | \"\n",
        "        f\"valid DA={result['valid_Directional_Accuracy_%']:.2f}% | alpha={result['alpha']:.3f}\"\n",
        "    )\n",
        "    print(\n",
        "        f\"  test  R2={result['test_R2']:.4f} | test  RMSE={result['test_RMSE']:.4f} | \"\n",
        "        f\"test  DA={result['test_Directional_Accuracy_%']:.2f}% | beat naive={result['test_Beat_Naive_Rate_%']:.2f}%\"\n",
        "    )\n",
        "\n",
        "    key = (result['valid_RMSE'], result['valid_MAPE_%'], -result['valid_R2'])\n",
        "    if best is None or key < best['key']:\n",
        "        best = {'key': key, 'result': result, 'detail': detail, 'history': history}\n",
        "\n",
        "results_df = pd.DataFrame(all_results).sort_values('valid_RMSE').reset_index(drop=True)\n",
        "results_df.to_excel(OUTPUT_DIR / 'gru_model_selection_fixed.xlsx', index=False)\n",
